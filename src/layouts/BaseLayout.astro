---
import '../styles/global.css'
import CustomCursor from '../components/layout/CustomCursor'
import ScrollToTop from '../components/ui/ScrollToTop'
import { buildPersonSchema, buildWebSiteSchema } from '../seo/jsonld'
import SEO from '../seo/SEO.astro'
import type { Locale, AlternateLink } from '../i18n/utils'

interface Props {
  title: string
  description: string
  canonicalUrl?: string
  ogImage?: string
  lang: Locale
  alternates?: AlternateLink[]
}

// eslint-disable-next-line @typescript-eslint/prefer-destructuring -- Astro.props destructuring pattern required in Astro frontmatter
const { title, description, canonicalUrl = Astro.url.href, ogImage, lang, alternates } = Astro.props

const personSchema = buildPersonSchema(lang)
const websiteSchema = buildWebSiteSchema(Astro.url.origin, lang)
---

<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <link rel="icon" type="image/png" href="/avatar.png" />
    <SEO
      title={title}
      description={description}
      canonicalUrl={canonicalUrl}
      ogImage={ogImage}
      lang={lang}
      alternates={alternates}
    />
    <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
    <script type="application/ld+json" set:html={JSON.stringify(websiteSchema)} />
  </head>
  <body>
    <!-- Flash of wrong theme prevention: inline script must be first child of body -->
    <script is:inline>
      ;(function () {
        var stored = localStorage.getItem('theme-color')
        var prefersDark = window.matchMedia('(prefers-color-scheme: dark)').matches
        document.body.className = stored || (prefersDark ? 'theme-dark' : 'theme-light')
      })()
    </script>
    <CustomCursor client:only="react" />
    <slot />
    <ScrollToTop client:visible />
    <script>
      import AOS from 'aos'
      import 'aos/dist/aos.css'
      // DOMContentLoaded may have already fired by the time this deferred module runs
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', () => {
          AOS.init({ duration: 1200, once: true })
        })
      } else {
        AOS.init({ duration: 1200, once: true })
      }
    </script>
  </body>
</html>
