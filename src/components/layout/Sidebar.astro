<!-- Hamburger button (mobile only) -->
<button id="hamburger" class="hamburger" aria-label="Toggle menu">
  <span></span>
  <span></span>
  <span></span>
</button>

<style>
  .sidebar {
    position: fixed;
    left: 0;
    top: 0;
    height: 100vh;
    width: 320px;
    background-color: var(--sidebar-bg, #34495e);
    color: #fff;
    z-index: 100;
    transition: all 0.5s ease;
    overflow-y: auto;
  }

  @media (min-width: 1200px) and (max-width: 1500px) {
    .sidebar {
      width: 288px;
    }
  }

  @media (max-width: 1199px) {
    .sidebar {
      transform: translateX(-100%);
    }

    .sidebar.menu-open {
      transform: translateX(0);
    }
  }

  .sidebar-inner {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 2rem;
    height: 100%;
  }

  .sidebar-logo a {
    font-size: 1.8rem;
    font-weight: 700;
    color: #fff;
    text-decoration: none;
  }

  .sidebar-logo span {
    color: #a9afc3;
  }

  .sidebar-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
  }

  .nav-link {
    display: block;
    padding: 0.6rem 1rem;
    color: rgba(255, 255, 255, 0.75);
    text-decoration: none;
    border-radius: 6px;
    font-size: 0.95rem;
    font-weight: 500;
    transition: all 0.3s ease;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .nav-link:hover,
  .nav-link.active {
    color: #fff;
    background: rgba(255, 255, 255, 0.1);
    padding-left: 1.5rem;
  }

  .sidebar-social {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
  }

  .sidebar-social a {
    color: rgba(255, 255, 255, 0.7);
    transition: color 0.3s ease;
  }

  .sidebar-social a:hover {
    color: #fff;
  }

  .hamburger {
    display: none;
    position: fixed;
    top: 1.5rem;
    left: 1.5rem;
    z-index: 200;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
  }

  @media (max-width: 1199px) {
    .hamburger {
      display: flex;
    }
  }

  .hamburger span {
    display: block;
    width: 25px;
    height: 2px;
    background: var(--color-heading, #1a1a1a);
    transition: all 0.3s ease;
  }

  :global(body.theme-dark) .hamburger span {
    background: #fff;
  }
</style>

<script>
  // Scrollspy via IntersectionObserver
  const sections = document.querySelectorAll<HTMLElement>(
    '#home, #about, #service, #portfolio, #contact',
  )
  const navLinks = document.querySelectorAll<HTMLAnchorElement>('.nav-link')

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          navLinks.forEach((link) => link.classList.remove('active'))
          const id = entry.target.getAttribute('id')
          const activeLink = document.querySelector<HTMLAnchorElement>(`.nav-link[href="#${id}"]`)
          if (activeLink) activeLink.classList.add('active')
        }
      })
    },
    { threshold: 0.4 },
  )

  sections.forEach((section) => observer.observe(section))
</script>

<script>
  // Hamburger toggle
  const hamburger = document.getElementById('hamburger')
  const sidebar = document.getElementById('sidebar')

  hamburger?.addEventListener('click', () => {
    sidebar?.classList.toggle('menu-open')
  })

  // Close sidebar when clicking a nav link (mobile)
  document.querySelectorAll('.nav-link').forEach((link) => {
    link.addEventListener('click', () => {
      sidebar?.classList.remove('menu-open')
    })
  })
</script>
