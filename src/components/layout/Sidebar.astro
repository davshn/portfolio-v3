---
import { getTranslation } from '../../i18n/utils'
import LangToggle from '../ui/LangToggle.astro'
import ThemeToggle from '../ui/ThemeToggle'

import type { Locale } from '../../i18n/utils'

interface Props {
  lang: Locale
}

const { lang } = Astro.props
const t = getTranslation(lang)
---

<aside id="sidebar" class="sidebar">
  <div class="sidebar-inner">
    <!-- Top avatar -->
    <div class="sidebar-avatar">
      <div class="avatar-circle">
        <img src="/assets/20230323_200654.jpg" alt="David Figueroa" width="72" height="72" loading="eager" />
      </div>
    </div>

    <!-- Logo/Name -->
    <div class="sidebar-logo">
      <a href="#home">David<span>.</span></a>
    </div>

    <!-- Nav -->
    <nav class="sidebar-nav" id="sidebar-nav">
      <ul>
        <li>
          <a href="#home" class="nav-link">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z"></path>
              <polyline points="9 22 9 12 15 12 15 22"></polyline>
            </svg>
            {t.nav.home}
          </a>
        </li>
        <li>
          <a href="#about" class="nav-link">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"></path>
              <circle cx="12" cy="7" r="4"></circle>
            </svg>
            {t.nav.about}
          </a>
        </li>
        <li>
          <a href="#service" class="nav-link">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect>
              <path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path>
            </svg>
            {t.nav.service}
          </a>
        </li>
        <li>
          <a href="#portfolio" class="nav-link">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <rect x="3" y="3" width="7" height="7"></rect>
              <rect x="14" y="3" width="7" height="7"></rect>
              <rect x="14" y="14" width="7" height="7"></rect>
              <rect x="3" y="14" width="7" height="7"></rect>
            </svg>
            {t.nav.portfolio}
          </a>
        </li>
        <li>
          <a href="#contact" class="nav-link">
            <svg
              xmlns="http://www.w3.org/2000/svg"
              width="16"
              height="16"
              viewBox="0 0 24 24"
              fill="none"
              stroke="currentColor"
              stroke-width="2"
              stroke-linecap="round"
              stroke-linejoin="round"
              aria-hidden="true"
            >
              <path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"
              ></path>
              <polyline points="22,6 12,13 2,6"></polyline>
            </svg>
            {t.nav.contact}
          </a>
        </li>
      </ul>
    </nav>

    <!-- Language Toggle -->
    <LangToggle lang={lang} />

    <!-- Theme Toggle island -->
    <ThemeToggle
      client:visible
      labelDark={t.common.themeToggle.dark}
      labelLight={t.common.themeToggle.light}
      ariaLabelDark={t.common.themeToggle.switchToDark}
      ariaLabelLight={t.common.themeToggle.switchToLight}
    />

    <!-- Spacer to push bottom bar down -->
    <div class="sidebar-spacer"></div>

    <!-- Bottom bar -->
    <div class="sidebar-bottom">
      <div class="bottom-avatar">
        <img src="/avatar.png" alt="David Figueroa" width="40" height="40" loading="lazy" />
      </div>
      <div class="bottom-info">
        <span class="bottom-name">David Figueroa</span>
        <span class="bottom-email">davshn@gmail.com</span>
      </div>
    </div>

    <!-- Social Icons (inline SVGs — Feather icon set) -->
    <div class="sidebar-social">
      <a
        href="https://twitter.com/davshmr"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="Twitter"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path
            d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"
          ></path></svg
        >
      </a>
      <a
        href="https://github.com/davshn"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="GitHub"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path
            d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"
          ></path></svg
        >
      </a>
      <a
        href="https://www.linkedin.com/in/davshn"
        target="_blank"
        rel="noopener noreferrer"
        aria-label="LinkedIn"
      >
        <svg
          xmlns="http://www.w3.org/2000/svg"
          width="20"
          height="20"
          viewBox="0 0 24 24"
          fill="none"
          stroke="currentColor"
          stroke-width="2"
          stroke-linecap="round"
          stroke-linejoin="round"
          ><path d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
          ></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"
          ></circle></svg
        >
      </a>
    </div>
  </div>
</aside>

<!-- Hamburger button (mobile only) -->
<button id="hamburger" class="hamburger" aria-label="Toggle menu">
  <span></span>
  <span></span>
  <span></span>
</button>

<style>
  .sidebar {
    position: fixed;
    left: 0;
    top: 0;
    height: 100vh;
    width: 320px;
    background-color: var(--sidebar-bg, #fff);
    border-right: var(--sidebar-border, 1px solid #ebebeb);
    color: var(--sidebar-nav-color, #7e7e7e);
    z-index: 100;
    transition: all 0.5s ease;
    overflow-y: auto;
  }

  @media (min-width: 1200px) and (max-width: 1500px) {
    .sidebar {
      width: 288px;
    }
  }

  @media (max-width: 1199px) {
    .sidebar {
      transform: translateX(-100%);
    }

    .sidebar.menu-open {
      transform: translateX(0);
    }
  }

  .sidebar-inner {
    padding: 2rem;
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    min-height: 100%;
  }

  /* Top avatar */
  .sidebar-avatar {
    display: flex;
    justify-content: center;
  }

  .avatar-circle {
    width: 72px;
    height: 72px;
    border-radius: 50%;
    background: var(--sidebar-avatar-bg, #f0f0f0);
    border: 2px solid var(--sidebar-avatar-border, #e0e0e0);
    display: flex;
    align-items: center;
    justify-content: center;
    overflow: hidden;
  }

  .avatar-circle img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  /* Logo */
  .sidebar-logo {
    text-align: center;
  }

  .sidebar-logo a {
    font-size: 1.8rem;
    font-weight: 700;
    color: var(--sidebar-logo-color, #1a1a1a);
    text-decoration: none;
  }

  .sidebar-logo span {
    color: var(--sidebar-logo-accent, #34495e);
  }

  /* Nav */
  .sidebar-nav ul {
    list-style: none;
    margin: 0;
    padding: 0;
    display: flex;
    flex-direction: column;
    gap: 0.25rem;
  }

  .nav-link {
    display: flex;
    align-items: center;
    gap: 0.65rem;
    padding: 0.6rem 1rem;
    color: var(--sidebar-nav-color, #7e7e7e);
    text-decoration: none;
    border-radius: 6px;
    font-size: 0.95rem;
    font-weight: 500;
    transition: all 0.3s ease;
    letter-spacing: 0.05em;
    text-transform: uppercase;
  }

  .nav-link:hover,
  .nav-link.active {
    color: var(--sidebar-nav-active-color, #34495e);
    background: var(--sidebar-nav-active-bg, rgba(52, 73, 94, 0.08));
    padding-left: 1.5rem;
  }

  /* Social */
  .sidebar-social {
    display: flex;
    gap: 1rem;
    flex-wrap: wrap;
    align-items: center;
    justify-content: center;
  }

  .sidebar-social a {
    color: var(--sidebar-icon-color, #aaaaaa);
    transition: color 0.3s ease;
  }

  .sidebar-social a:hover {
    color: var(--sidebar-icon-hover, #34495e);
  }

  /* Spacer */
  .sidebar-spacer {
    flex: 1;
  }

  /* Bottom bar */
  .sidebar-bottom {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 1rem;
    border-top: var(--sidebar-bottom-border, 1px solid #ebebeb);
    margin: 0 -0.5rem -0.5rem;
  }

  .bottom-avatar {
    width: 40px;
    height: 40px;
    border-radius: 50%;
    background: var(--sidebar-avatar-bg, #f0f0f0);
    border: 2px solid var(--sidebar-avatar-border, #e0e0e0);
    display: flex;
    align-items: center;
    justify-content: center;
    flex-shrink: 0;
    overflow: hidden;
  }

  .bottom-avatar img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .bottom-info {
    display: flex;
    flex-direction: column;
    gap: 0.1rem;
    overflow: hidden;
  }

  .bottom-name {
    font-size: 0.85rem;
    font-weight: 600;
    color: var(--sidebar-logo-color, #1a1a1a);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  .bottom-email {
    font-size: 0.72rem;
    color: var(--sidebar-nav-color, #7e7e7e);
    white-space: nowrap;
    overflow: hidden;
    text-overflow: ellipsis;
  }

  /* Hamburger */
  .hamburger {
    display: none;
    position: fixed;
    top: 1.5rem;
    left: 1.5rem;
    z-index: 200;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 0.5rem;
  }

  @media (max-width: 1199px) {
    .hamburger {
      display: flex;
    }
  }

  .hamburger span {
    display: block;
    width: 25px;
    height: 2px;
    background: var(--color-heading, #1a1a1a);
    transition: all 0.3s ease;
  }

  :global(body.theme-dark) .hamburger span {
    background: #fff;
  }

  /* Dark theme avatar colors */
  :global(body.theme-dark) .avatar-circle,
  :global(body.theme-dark) .bottom-avatar {
    background: rgba(255, 255, 255, 0.1);
    border-color: rgba(255, 255, 255, 0.2);
  }

  :global(body.theme-dark) .sidebar-bottom {
    border-top-color: rgba(255, 255, 255, 0.15);
  }
</style>

<script>
  // Scrollspy via IntersectionObserver
  const sections = document.querySelectorAll<HTMLElement>(
    '#home, #about, #service, #portfolio, #contact',
  )
  const navLinks = document.querySelectorAll<HTMLAnchorElement>('.nav-link')

  const observer = new IntersectionObserver(
    (entries) => {
      entries.forEach((entry) => {
        if (entry.isIntersecting) {
          navLinks.forEach((link) => link.classList.remove('active'))
          const id = entry.target.getAttribute('id')
          const activeLink = document.querySelector<HTMLAnchorElement>(`.nav-link[href="#${id}"]`)
          if (activeLink) activeLink.classList.add('active')
        }
      })
    },
    { threshold: 0.4 },
  )

  sections.forEach((section) => observer.observe(section))
</script>

<script>
  // Hamburger toggle
  const hamburger = document.getElementById('hamburger')
  const sidebar = document.getElementById('sidebar')

  hamburger?.addEventListener('click', () => {
    sidebar?.classList.toggle('menu-open')
  })

  // Close sidebar when clicking a nav link (mobile)
  document.querySelectorAll('.nav-link').forEach((link) => {
    link.addEventListener('click', () => {
      sidebar?.classList.remove('menu-open')
    })
  })
</script>
