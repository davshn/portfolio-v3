---
import Button from '../ui/Button.astro'

import TypedHero from './TypedHero'
---

<section id="home" class="hero-section">
  <div class="hero-container">
    <!-- Photo column -->
    <div class="hero-photo-col" data-aos="fade-right" data-aos-duration="1200">
      <!-- Replace with <Image> from astro:assets once hero-photo.jpg is available -->
      <div class="hero-photo-placeholder" aria-label="David Figueroa - Fullstack Developer">
        <span>DF</span>
      </div>
    </div>

    <!-- Text column -->
    <div class="hero-text-col" data-aos="fade-left" data-aos-duration="1200">
      <h4 class="hero-greeting">Hello, I'm</h4>
      <h1 class="hero-name">David Figueroa</h1>
      <h3 class="hero-typed">
        <TypedHero client:load />
      </h3>
      <p class="hero-bio">
        Senior Mobile Engineer specializing in fintech and secure payments, with 9+ years building production React Native apps from zero to scale.
      </p>

      <!-- Social icons -->
      <div class="hero-social">
        <a
          href="https://www.facebook.com/david.figueroa.184"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Facebook"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path d="M18 2h-3a5 5 0 0 0-5 5v3H7v4h3v8h4v-8h3l1-4h-4V7a1 1 0 0 1 1-1h3z"
            ></path></svg
          >
        </a>
        <a
          href="https://twitter.com/davshmr"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Twitter"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path
              d="M23 3a10.9 10.9 0 0 1-3.14 1.53 4.48 4.48 0 0 0-7.86 3v1A10.66 10.66 0 0 1 3 4s-4 9 5 13a11.64 11.64 0 0 1-7 2c9 5 20 0 20-11.5a4.5 4.5 0 0 0-.08-.83A7.72 7.72 0 0 0 23 3z"
            ></path></svg
          >
        </a>
        <a
          href="https://www.instagram.com/davidfigueroa9055"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="Instagram"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><rect x="2" y="2" width="20" height="20" rx="5" ry="5"></rect><path
              d="M16 11.37A4 4 0 1 1 12.63 8 4 4 0 0 1 16 11.37z"></path><line
              x1="17.5"
              y1="6.5"
              x2="17.51"
              y2="6.5"></line></svg
          >
        </a>
        <a
          href="https://github.com/davshn"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="GitHub"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path
              d="M9 19c-5 1.5-5-2.5-7-3m14 6v-3.87a3.37 3.37 0 0 0-.94-2.61c3.14-.35 6.44-1.54 6.44-7A5.44 5.44 0 0 0 20 4.77 5.07 5.07 0 0 0 19.91 1S18.73.65 16 2.48a13.38 13.38 0 0 0-7 0C6.27.65 5.09 1 5.09 1A5.07 5.07 0 0 0 5 4.77a5.44 5.44 0 0 0-1.5 3.78c0 5.42 3.3 6.61 6.44 7A3.37 3.37 0 0 0 9 18.13V22"
            ></path></svg
          >
        </a>
        <a
          href="https://www.linkedin.com/in/davshn"
          target="_blank"
          rel="noopener noreferrer"
          aria-label="LinkedIn"
        >
          <svg
            xmlns="http://www.w3.org/2000/svg"
            width="20"
            height="20"
            viewBox="0 0 24 24"
            fill="none"
            stroke="currentColor"
            stroke-width="2"
            stroke-linecap="round"
            stroke-linejoin="round"
            ><path
              d="M16 8a6 6 0 0 1 6 6v7h-4v-7a2 2 0 0 0-2-2 2 2 0 0 0-2 2v7h-4v-7a6 6 0 0 1 6-6z"
            ></path><rect x="2" y="9" width="4" height="12"></rect><circle cx="4" cy="4" r="2"
            ></circle></svg
          >
        </a>
      </div>

      <div class="hero-cta" data-aos-delay="200">
        <Button label="View CV" href="/cv-hernan-figueroa.html" />
      </div>
    </div>
  </div>
</section>

<style>
  .hero-section {
    min-height: 100vh;
    display: flex;
    align-items: center;
    background-color: var(--hero-bg, #fff);
    padding: 6rem 4rem 4rem;
  }

  body.theme-dark .hero-section {
    background-color: #191c26;
  }

  .hero-container {
    display: flex;
    align-items: center;
    gap: 4rem;
    max-width: 900px;
    width: 100%;
    margin: 0 auto;
  }

  .hero-photo-col {
    flex-shrink: 0;
  }

  .hero-photo-placeholder {
    width: 220px;
    height: 220px;
    border-radius: 50%;
    background: linear-gradient(135deg, #34495e 0%, #2c3e50 100%);
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 3rem;
    font-weight: 700;
    color: #fff;
    box-shadow: 0 20px 60px rgba(52, 73, 94, 0.3);
  }

  .hero-text-col {
    flex: 1;
  }

  .hero-greeting {
    color: var(--color-brand, #34495e);
    font-size: 1rem;
    font-weight: 500;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    margin-bottom: 0.5rem;
  }

  .hero-name {
    font-size: 3rem;
    font-weight: 800;
    color: var(--color-heading, #1a1a1a);
    margin-bottom: 0.5rem;
    line-height: 1.1;
  }

  body.theme-dark .hero-name {
    color: #fff;
  }

  .hero-typed {
    font-size: 1.4rem;
    font-weight: 400;
    color: var(--color-brand, #34495e);
    margin-bottom: 1.5rem;
    min-height: 2rem;
  }

  .hero-bio {
    color: var(--color-text, #7e7e7e);
    font-size: 1rem;
    line-height: 1.7;
    margin-bottom: 2rem;
    max-width: 480px;
  }

  .hero-social {
    display: flex;
    gap: 1rem;
    margin-bottom: 2rem;
  }

  .hero-social a {
    color: var(--color-text, #7e7e7e);
    transition:
      color 0.3s ease,
      transform 0.3s ease;
    display: flex;
    align-items: center;
  }

  .hero-social a:hover {
    color: var(--color-brand, #34495e);
    transform: translateY(-2px);
  }

  @media (max-width: 768px) {
    .hero-section {
      padding: 6rem 2rem 4rem;
    }
    .hero-container {
      flex-direction: column;
      text-align: center;
      gap: 2rem;
    }
    .hero-social {
      justify-content: center;
    }
    .hero-name {
      font-size: 2rem;
    }
  }
</style>
