---
import type { Locale } from '../../i18n/utils'
import { getTranslation } from '../../i18n/utils'
import { getLocalizedCollection } from '../../i18n/getCollection'

import ServiceCards from './ServiceCards'

interface Props {
  lang: Locale
}

const { lang } = Astro.props
const t = getTranslation(lang)

const servicesCollection = await getLocalizedCollection('services', lang)

const services = servicesCollection
  .sort((a, b) => a.data.order - b.data.order)
  .map((entry) => ({
    id: entry.id.replace(/^(en|es)\//, ''),
    title: entry.data.title,
    shortDescription: entry.data.shortDescription,
    body: entry.body,
    order: entry.data.order,
  }))
---

<section id="service" class="service-section">
  <div class="service-container">
    <div class="section-header" data-aos="fade-up" data-aos-duration="1200">
      <div class="section-label">{t.service.sectionLabel}</div>
      <h2 class="section-title">{t.service.sectionTitle}</h2>
    </div>

    <ServiceCards client:only="react" services={services} messages={t.service} />
  </div>
</section>

<style>
  .service-section {
    padding: 6rem 4rem;
    background: #fff;
  }

  body.theme-dark .service-section {
    background: #111319;
  }

  .service-container {
    max-width: 900px;
    margin: 0 auto;
  }

  .section-header {
    text-align: center;
    margin-bottom: 3rem;
  }

  .section-label {
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #34495e;
    margin-bottom: 0.5rem;
  }

  .section-title {
    font-size: 2.25rem;
    font-weight: 800;
    color: #1a1a1a;
  }

  body.theme-dark .section-title {
    color: #fff;
  }

  @media (max-width: 768px) {
    .service-section {
      padding: 4rem 2rem;
    }
  }
</style>
