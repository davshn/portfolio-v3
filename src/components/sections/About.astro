---
import type { Locale } from '../../i18n/utils'
import { getTranslation } from '../../i18n/utils'
import educationEnData from '../../content/education.json'
import educationEsData from '../../content/education.es.json'
import experienceEnData from '../../content/experience.json'
import experienceEsData from '../../content/experience.es.json'
import skillsEnData from '../../content/skills.json'
import skillsEsData from '../../content/skills.es.json'
import Badge from '../ui/Badge.astro'
import ProgressBar from '../ui/ProgressBar.astro'

import AboutIsland from './AboutIsland'

interface Props {
  lang: Locale
}

const { lang } = Astro.props
const t = getTranslation(lang)

const skillsData = lang === 'es' ? skillsEsData : skillsEnData
const experienceData = lang === 'es' ? experienceEsData : experienceEnData
const educationData = lang === 'es' ? educationEsData : educationEnData
---

<section id="about" class="about-section">
  <div class="about-container">
    <!-- Left column: bio + skill bars -->
    <div class="about-left" data-aos="fade-right" data-aos-duration="1200">
      <div class="section-label">{t.about.sectionLabel}</div>
      <h2 class="section-title">{t.about.sectionTitle}</h2>
      <p class="about-bio">
        {t.about.bioP1}
      </p>
      <p class="about-bio">
        {t.about.bioP2}
      </p>

      <div class="skills-section">
        <h3>{t.about.skillsHeading}</h3>
        {skillsData.map((skill) => <ProgressBar label={skill.name} percentage={skill.percent} />)}
      </div>
    </div>

    <!-- Right column: photo + badge + see more -->
    <div class="about-right" data-aos="fade-left" data-aos-duration="1200">
      <div class="about-photo-wrapper">
        <div class="about-photo">
          <img src="/assets/20230323_200654.jpg" alt="David Figueroa" loading="lazy" />
        </div>
        <div class="about-badge-wrapper">
          <Badge text={t.about.experienceBadge} />
        </div>
      </div>

      <AboutIsland
        client:only="react"
        experience={experienceData}
        education={educationData}
        messages={t.about}
      />
    </div>
  </div>
</section>

<style>
  .about-section {
    padding: 6rem 4rem;
    background: var(--section-alt-bg, #f5f5f5);
  }

  body.theme-dark .about-section {
    background: #111319;
  }

  .about-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    max-width: 900px;
    margin: 0 auto;
    align-items: start;
  }

  .section-label {
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-brand, #34495e);
    margin-bottom: 0.5rem;
  }

  .section-title {
    font-size: 2.25rem;
    font-weight: 800;
    color: var(--color-heading, #1a1a1a);
    margin-bottom: 1.5rem;
  }

  body.theme-dark .section-title {
    color: #fff;
  }

  .about-bio {
    color: var(--color-text, #7e7e7e);
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .skills-section h3 {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 1rem;
    margin-top: 1.5rem;
    color: var(--color-heading, #1a1a1a);
  }

  body.theme-dark .skills-section h3 {
    color: #fff;
  }

  .about-photo-wrapper {
    position: relative;
    margin-bottom: 2rem;
  }

  .about-photo {
    width: 100%;
    aspect-ratio: 3/4;
    border-radius: 12px;
    overflow: hidden;
    max-height: 400px;
  }

  .about-photo img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center 40%;
    display: block;
  }

  .about-badge-wrapper {
    position: absolute;
    bottom: -1rem;
    left: -1rem;
    background: #fff;
    padding: 0.5rem;
    border-radius: 8px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
  }

  body.theme-dark .about-badge-wrapper {
    background: #191c26;
  }

  @media (max-width: 768px) {
    .about-section {
      padding: 4rem 2rem;
    }
    .about-container {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
