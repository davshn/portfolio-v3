---
import educationData from '../../content/education.json'
import experienceData from '../../content/experience.json'
import skillsData from '../../content/skills.json'
import Badge from '../ui/Badge.astro'
import ProgressBar from '../ui/ProgressBar.astro'

import AboutIsland from './AboutIsland'
---

<section id="about" class="about-section">
  <div class="about-container">
    <!-- Left column: bio + skill bars -->
    <div class="about-left" data-aos="fade-right" data-aos-duration="1200">
      <div class="section-label">Who am I?</div>
      <h2 class="section-title">About Me</h2>
      <p class="about-bio">
        Senior Mobile Engineer specializing in fintech and secure payments, with 9+ years building
        production React Native apps from zero to scale. I've shipped a logistics platform used
        across Latin America, grown a fintech app from its first user to 500+ daily active clients,
        and implemented PCI DSS-compliant security layers at one of Colombia's leading payment gateways.
      </p>
      <p class="about-bio">
        Based in Bogota, Colombia. Available for freelance and open to new opportunities.
        I work in both Spanish and English.
      </p>

      <div class="skills-section">
        <h3>My Skills</h3>
        {skillsData.map((skill) => <ProgressBar label={skill.name} percentage={skill.percent} />)}
      </div>
    </div>

    <!-- Right column: photo + badge + see more -->
    <div class="about-right" data-aos="fade-left" data-aos-duration="1200">
      <div class="about-photo-wrapper">
        <!-- Replace with <Image> from astro:assets once about-photo.jpg is available -->
        <div class="about-photo-placeholder" aria-label="David Figueroa">
          <span>DF</span>
        </div>
        <div class="about-badge-wrapper">
          <Badge text="9+ Years of Experience" />
        </div>
      </div>

      <AboutIsland client:only="react" experience={experienceData} education={educationData} />
    </div>
  </div>
</section>

<style>
  .about-section {
    padding: 6rem 4rem;
    background: var(--section-alt-bg, #f5f5f5);
  }

  body.theme-dark .about-section {
    background: #111319;
  }

  .about-container {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 4rem;
    max-width: 900px;
    margin: 0 auto;
    align-items: start;
  }

  .section-label {
    font-size: 0.85rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-brand, #34495e);
    margin-bottom: 0.5rem;
  }

  .section-title {
    font-size: 2.25rem;
    font-weight: 800;
    color: var(--color-heading, #1a1a1a);
    margin-bottom: 1.5rem;
  }

  body.theme-dark .section-title {
    color: #fff;
  }

  .about-bio {
    color: var(--color-text, #7e7e7e);
    line-height: 1.8;
    margin-bottom: 1rem;
  }

  .skills-section h3 {
    font-size: 1.1rem;
    font-weight: 700;
    margin-bottom: 1rem;
    margin-top: 1.5rem;
    color: var(--color-heading, #1a1a1a);
  }

  body.theme-dark .skills-section h3 {
    color: #fff;
  }

  .about-photo-wrapper {
    position: relative;
    margin-bottom: 2rem;
  }

  .about-photo-placeholder {
    width: 100%;
    aspect-ratio: 3/4;
    background: linear-gradient(135deg, #34495e 0%, #2c3e50 100%);
    border-radius: 12px;
    display: flex;
    align-items: center;
    justify-content: center;
    font-size: 4rem;
    font-weight: 700;
    color: #fff;
    max-height: 400px;
  }

  .about-badge-wrapper {
    position: absolute;
    bottom: -1rem;
    left: -1rem;
    background: #fff;
    padding: 0.5rem;
    border-radius: 8px;
    box-shadow: 0 4px 20px rgba(0, 0, 0, 0.1);
  }

  body.theme-dark .about-badge-wrapper {
    background: #191c26;
  }

  @media (max-width: 768px) {
    .about-section {
      padding: 4rem 2rem;
    }
    .about-container {
      grid-template-columns: 1fr;
      gap: 2rem;
    }
  }
</style>
